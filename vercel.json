{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/pvgis-monthly",
      "destination": "/api/pvgis-monthly.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}